<Window x:Class="ArchiveViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Archive Viewer" Icon="app.ico" Width="1400" Height="850" MinWidth="800" MinHeight="600"
        Background="{DynamicResource ThemeBg}" WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown" PreviewMouseWheel="Window_PreviewMouseWheel"
        PreviewMouseUp="Window_PreviewMouseUp"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        Closing="Window_Closing" Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemePanel}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
        </Style>

        <Style x:Key="ModeButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource ThemePanel}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSubtext}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeAccent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ThemeBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeText}"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="HeaderRow" Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border x:Name="HeaderBar" Grid.Row="0" Background="{DynamicResource ThemePanel}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📦" FontFamily="Segoe UI Emoji" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ToggleButton x:Name="BtnRating" Content="閲覧" Style="{StaticResource ModeButton}" Click="BtnRating_Click" Margin="0,0,2,0"/>
                    <ToggleButton x:Name="BtnExtract" Content="抽出" Style="{StaticResource ModeButton}" Click="BtnExtract_Click" Margin="0,0,2,0"/>
                    <ToggleButton x:Name="BtnVideo" Content="動画" Style="{StaticResource ModeButton}" Click="BtnVideo_Click" Margin="0,0,2,0"/>
                    <ToggleButton x:Name="BtnImage" Content="画像" Style="{StaticResource ModeButton}" Click="BtnImage_Click" Margin="0,0,2,0"/>
                    <ToggleButton x:Name="BtnBrowse" Content="旧閲覧" Style="{StaticResource ModeButton}" Click="BtnBrowse_Click" Margin="0,0,12,0" Visibility="Collapsed"/>

                    <Border Width="1" Background="{DynamicResource ThemeBorder}" Margin="0,8"/>

                    <ToggleButton x:Name="BtnSortName" Content="名前順" Style="{StaticResource ModeButton}" Click="BtnSortName_Click" IsChecked="True" Margin="12,0,2,0"/>
                    <ToggleButton x:Name="BtnSortDate" Content="更新日順" Style="{StaticResource ModeButton}" Click="BtnSortDate_Click" Margin="0,0,2,0"/>
                    <ToggleButton x:Name="BtnSortRandom" Content="ランダム" Style="{StaticResource ModeButton}" Click="BtnSortRandom_Click" Margin="0,0,12,0"/>

                    <Border Width="1" Background="{DynamicResource ThemeBorder}" Margin="0,8"/>

                    <ToggleButton x:Name="BtnPortrait" Content="縦" Style="{StaticResource ModeButton}" Click="BtnPortrait_Click" IsChecked="True" Margin="12,0,2,0"/>
                    <ToggleButton x:Name="BtnLandscape" Content="横" Style="{StaticResource ModeButton}" Click="BtnLandscape_Click" Margin="0,0,12,0"/>

                    <Border Width="1" Background="{DynamicResource ThemeBorder}" Margin="0,8"/>

                    <Button x:Name="BtnOpen" Content="📁 開く" Style="{StaticResource DarkButton}" Click="BtnOpen_Click" Margin="12,0,4,0" FontFamily="Segoe UI Emoji, Yu Gothic UI"/>

                    <Button x:Name="BtnExtractRange" Content="✂️ 範囲を抽出" Style="{StaticResource AccentButton}"
                            Click="BtnExtractRange_Click" Visibility="Collapsed" Margin="4,0,2,0"/>
                    <Button x:Name="BtnClearSelection" Content="🗑 選択解除" Style="{StaticResource DarkButton}"
                            Click="BtnClearSelection_Click" Visibility="Collapsed" Margin="2,0,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="TxtPrevFile" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,4,0"
                               MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                    <Button x:Name="BtnPrev" Content="◀" Style="{StaticResource DarkButton}" Click="BtnPrev_Click"
                            Padding="6,4" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtCurrentFile" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14"
                               VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,2,0"
                               MaxWidth="350" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TxtFilePosition" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button x:Name="BtnNext" Content="▶" Style="{StaticResource DarkButton}" Click="BtnNext_Click"
                            Padding="6,4" Margin="0,0,4,0"/>
                    <TextBlock x:Name="TxtNextFile" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="14"
                               VerticalAlignment="Center"
                               MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="RightSidebarCol" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="0" Background="{DynamicResource ThemePanel}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                <ScrollViewer x:Name="SidebarScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="LeftSidebar" Margin="12"/>
                </ScrollViewer>
            </Border>

            <!-- MAIN AREA -->
            <Grid Grid.Column="1">
                <ScrollViewer x:Name="GridScroller" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Background="{DynamicResource ThemeBg}">
                    <WrapPanel x:Name="ThumbnailGrid" Margin="8"/>
                </ScrollViewer>

                <StackPanel x:Name="EmptyMessage" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="📦" FontFamily="Segoe UI Emoji" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="アーカイブをドロップまたは「開く」で選択" Foreground="{DynamicResource ThemeSubtext}"
                               FontFamily="Yu Gothic UI" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <Border x:Name="ProgressOverlay" Background="{DynamicResource ThemeBgOverlay}" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar x:Name="LoadProgress" Width="300" Height="20" Minimum="0" Maximum="100"
                                     Foreground="{DynamicResource ThemeAccent}" Background="{DynamicResource ThemePanel}"/>
                        <TextBlock x:Name="ProgressText" Text="読み込み中..." Foreground="{DynamicResource ThemeText}"
                                   FontFamily="Yu Gothic UI" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Image Viewer Overlay -->
                <Grid x:Name="ViewerOverlay" Visibility="Collapsed" Background="{DynamicResource ThemeBg}"
                      MouseLeftButtonDown="ViewerOverlay_MouseLeftButtonDown"
                      MouseMove="ViewerOverlay_MouseMove">
                    <Image x:Name="ViewerImage" Stretch="Uniform" Margin="8"/>
                    <Border x:Name="ViewerBottomBar" VerticalAlignment="Bottom" Height="80"
                            Background="{DynamicResource ThemePanelOverlay}" Opacity="0" IsHitTestVisible="True"
                            MouseEnter="ViewerBottomBar_MouseEnter" MouseLeave="ViewerBottomBar_MouseLeave">
                        <StackPanel VerticalAlignment="Center" Margin="16,0">
                            <Slider x:Name="ViewerSlider" Minimum="0" Maximum="100"
                                    ValueChanged="ViewerSlider_ValueChanged" Margin="0,0,0,4"/>
                            <TextBlock x:Name="ViewerInfo" Foreground="{DynamicResource ThemeSubtext}"
                                       FontFamily="Yu Gothic UI" FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Video Player Overlay -->
                <Grid x:Name="VideoOverlay" Visibility="Collapsed" Background="{DynamicResource ThemeBg}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="VideoViewHost" Grid.Row="0" Background="Black"/>

                    <Border Grid.Row="1" Background="{DynamicResource ThemePanel}" Padding="8">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock x:Name="VideoTimeText" DockPanel.Dock="Right" Foreground="{DynamicResource ThemeSubtext}"
                                           FontFamily="Yu Gothic UI" FontSize="13" VerticalAlignment="Center"
                                           Margin="8,0,0,0" Text="00:00 / 00:00"/>
                                <Canvas x:Name="SeekBarCanvas" Height="20" Background="Transparent"
                                        MouseLeftButtonDown="SeekBar_MouseDown" MouseMove="SeekBar_MouseMove"
                                        MouseLeftButtonUp="SeekBar_MouseUp"/>
                            </DockPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Button Content="⏮" Style="{StaticResource AccentButton}" Click="BtnVideoPrev_Click" Padding="8,4" Margin="4,0" ToolTip="前の動画" FontSize="14"/>
                                <Button Content="⏪10m" Style="{StaticResource DarkButton}" Click="VideoSkip_Click" Tag="-600" Padding="4,2" Margin="1,0"/>
                                <Button Content="⏪3m" Style="{StaticResource DarkButton}" Click="VideoSkip_Click" Tag="-180" Padding="4,2" Margin="1,0"/>
                                <Button Content="⏪30s" Style="{StaticResource DarkButton}" Click="VideoSkip_Click" Tag="-30" Padding="4,2" Margin="1,0"/>
                                <Button Content="⏪10s" Style="{StaticResource DarkButton}" Click="VideoSkip_Click" Tag="-10" Padding="4,2" Margin="1,0"/>
                                <Button x:Name="BtnPlayPause" Content="▶" Style="{StaticResource AccentButton}" Click="BtnPlayPause_Click" Padding="12,4" Margin="4,0"/>
                                <Button Content="10s⏩" Style="{StaticResource DarkButton}" Click="VideoSkip_Click" Tag="10" Padding="4,2" Margin="1,0"/>
                                <Button Content="30s⏩" Style="{StaticResource DarkButton}" Click="VideoSkip_Click" Tag="30" Padding="4,2" Margin="1,0"/>
                                <Button Content="3m⏩" Style="{StaticResource DarkButton}" Click="VideoSkip_Click" Tag="180" Padding="4,2" Margin="1,0"/>
                                <Button Content="10m⏩" Style="{StaticResource DarkButton}" Click="VideoSkip_Click" Tag="600" Padding="4,2" Margin="1,0"/>
                                <Button Content="⏭" Style="{StaticResource AccentButton}" Click="BtnVideoNext_Click" Padding="8,4" Margin="4,0" ToolTip="次の動画" FontSize="14"/>
                            </StackPanel>

                            <DockPanel>
                                <Button Content="✕ 閉じる" Style="{StaticResource DarkButton}" DockPanel.Dock="Right"
                                        Click="BtnCloseVideo_Click" Padding="8,2"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="音量:" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Slider x:Name="VolumeSlider" Width="100" Minimum="0" Maximum="100"
                                            Value="80" ValueChanged="VolumeSlider_ValueChanged" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="VolumeText" Text="80%" Foreground="{DynamicResource ThemeSubtext}"
                                               FontFamily="Yu Gothic UI" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>

                                    <TextBlock Text="終了時:" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="13"
                                               VerticalAlignment="Center" Margin="16,0,4,0"/>
                                    <RadioButton x:Name="RbEndStop" Content="停止" GroupName="VideoEnd" IsChecked="True"
                                                 Click="VideoEndAction_Click" Tag="stop" VerticalAlignment="Center" Margin="2,0"
                                                 Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="13"/>
                                    <RadioButton x:Name="RbEndLoop" Content="リピート" GroupName="VideoEnd"
                                                 Click="VideoEndAction_Click" Tag="loop" VerticalAlignment="Center" Margin="2,0"
                                                 Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="13"/>
                                    <RadioButton x:Name="RbEndNext" Content="次の動画" GroupName="VideoEnd"
                                                 Click="VideoEndAction_Click" Tag="next" VerticalAlignment="Center" Margin="2,0"
                                                 Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="13"/>
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- RIGHT SIDEBAR (Extract mode only) -->
            <Border x:Name="RightSidebar" Grid.Column="2" Background="{DynamicResource ThemePanel}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1,0,0,0" Visibility="Collapsed">
                <DockPanel Margin="12">
                    <Button DockPanel.Dock="Top" Content="選択範囲をリストに追加"
                            Style="{StaticResource AccentButton}" Click="BtnAddToExtractList_Click" Margin="0,0,0,8"/>
                    <Button DockPanel.Dock="Bottom" Content="抽出実行"
                            Style="{StaticResource AccentButton}" Click="BtnExecuteExtract_Click" Margin="0,8,0,0"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ExtractListPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="{DynamicResource ThemePanel}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
            <DockPanel Margin="8,0">
                <TextBlock x:Name="TxtFileSize" DockPanel.Dock="Left" Foreground="{DynamicResource ThemeSubtext}"
                           FontFamily="Yu Gothic UI" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtSelectionInfo" DockPanel.Dock="Right" Foreground="{DynamicResource ThemeSubtext}"
                           FontFamily="Yu Gothic UI" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatus" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="13"
                           VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="TxtStatus_Click"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
