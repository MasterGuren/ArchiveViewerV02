<Window x:Class="ArchiveViewer.Dialogs.NameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="抽出ファイル名" Width="420" Height="280" WindowStartupLocation="CenterOwner"
        Background="#3d1a30" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="作者名" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,4"/>
        <TextBox x:Name="AuthorBox" Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"
                 CaretBrush="#fce4ec" FontFamily="Yu Gothic UI" Padding="4" TextChanged="OnTextChanged"/>

        <TextBlock Text="作品名" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,8,0,4"/>
        <TextBox x:Name="TitleBox" Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"
                 CaretBrush="#fce4ec" FontFamily="Yu Gothic UI" Padding="4" TextChanged="OnTextChanged"/>

        <TextBlock Text="話数" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,8,0,4"/>
        <TextBox x:Name="EpisodeBox" Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"
                 CaretBrush="#fce4ec" FontFamily="Yu Gothic UI" Padding="4" TextChanged="OnTextChanged"/>

        <TextBlock Text="元ファイル名" Foreground="#d4a0b0" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,8,0,4"/>
        <TextBlock x:Name="OriginalName" Foreground="#d4a0b0" FontFamily="Yu Gothic UI" FontSize="14"/>

        <TextBlock Text="→ 出力ファイル名:" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="13" Margin="0,8,0,2"/>
        <TextBlock x:Name="PreviewName" Foreground="#f06292" FontFamily="Yu Gothic UI" FontSize="13" FontWeight="Bold"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnOk_Click"
                    Background="#e91e63" Foreground="#fce4ec" BorderBrush="#7a4868"/>
            <Button Content="キャンセル" Width="80" Padding="4" Click="BtnCancel_Click"
                    Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"/>
        </StackPanel>
    </StackPanel>
</Window>
