<Window x:Class="ArchiveViewer.Dialogs.NameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="抽出ファイル名" Width="420" Height="280" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBg}" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="作者名" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,4"/>
        <TextBox x:Name="AuthorBox" Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"
                 CaretBrush="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" Padding="4" TextChanged="OnTextChanged"/>

        <TextBlock Text="作品名" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,8,0,4"/>
        <TextBox x:Name="TitleBox" Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"
                 CaretBrush="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" Padding="4" TextChanged="OnTextChanged"/>

        <TextBlock Text="話数" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,8,0,4"/>
        <TextBox x:Name="EpisodeBox" Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"
                 CaretBrush="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" Padding="4" TextChanged="OnTextChanged"/>

        <TextBlock Text="元ファイル名" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,8,0,4"/>
        <TextBlock x:Name="OriginalName" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="14"/>

        <TextBlock Text="→ 出力ファイル名:" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="13" Margin="0,8,0,2"/>
        <TextBlock x:Name="PreviewName" Foreground="{DynamicResource ThemeSelect}" FontFamily="Yu Gothic UI" FontSize="13" FontWeight="Bold"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnOk_Click"
                    Background="{DynamicResource ThemeAccent}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="キャンセル" Width="80" Padding="4" Click="BtnCancel_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
        </StackPanel>
    </StackPanel>
</Window>
