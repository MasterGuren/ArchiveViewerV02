<Window x:Class="ArchiveViewer.Dialogs.CategorySelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="カテゴリ変更" Width="320" Height="280" WindowStartupLocation="CenterOwner"
        Background="#3d1a30" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="カテゴリを選択:" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,8"/>
        <ListBox x:Name="CategoryList" Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"
                 FontFamily="Yu Gothic UI" FontSize="13" Height="100"
                 MouseDoubleClick="CategoryList_DoubleClick"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnOk_Click"
                    Background="#e91e63" Foreground="#fce4ec" BorderBrush="#7a4868"/>
            <Button Content="キャンセル" Width="80" Padding="4" Click="BtnCancel_Click"
                    Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"/>
        </StackPanel>
    </StackPanel>
</Window>
