<Window x:Class="ArchiveViewer.Dialogs.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="処理中" Width="400" Height="130" WindowStartupLocation="CenterOwner"
        Background="#3d1a30" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" BorderBrush="#7a4868" BorderThickness="1">
    <StackPanel VerticalAlignment="Center" Margin="24,0">
        <TextBlock x:Name="MessageText" Text="処理中..." Foreground="#fce4ec"
                   FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,4"/>
        <TextBlock x:Name="PercentText" Text="" Foreground="#d4a0b0"
                   FontFamily="Yu Gothic UI" FontSize="13" Margin="0,0,0,4"/>
        <ProgressBar x:Name="Progress" Height="16" Minimum="0" Maximum="100"
                     Foreground="#e91e63" Background="#502842"/>
    </StackPanel>
</Window>
