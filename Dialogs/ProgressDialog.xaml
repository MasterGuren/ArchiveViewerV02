<Window x:Class="ArchiveViewer.Dialogs.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="処理中" Width="400" Height="130" WindowStartupLocation="CenterOwner"
        Background="#1e1e2e" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" BorderBrush="#3f3f5e" BorderThickness="1">
    <StackPanel VerticalAlignment="Center" Margin="24,0">
        <TextBlock x:Name="MessageText" Text="処理中..." Foreground="#e2e8f0"
                   FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,4"/>
        <TextBlock x:Name="PercentText" Text="" Foreground="#94a3b8"
                   FontFamily="Yu Gothic UI" FontSize="13" Margin="0,0,0,4"/>
        <ProgressBar x:Name="Progress" Height="16" Minimum="0" Maximum="100"
                     Foreground="#7c3aed" Background="#2a2a3e"/>
    </StackPanel>
</Window>
