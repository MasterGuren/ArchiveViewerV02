<Window x:Class="ArchiveViewer.Dialogs.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="処理中" Width="400" Height="130" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBg}" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
    <StackPanel VerticalAlignment="Center" Margin="24,0">
        <TextBlock x:Name="MessageText" Text="処理中..." Foreground="{DynamicResource ThemeText}"
                   FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,4"/>
        <TextBlock x:Name="PercentText" Text="" Foreground="{DynamicResource ThemeSubtext}"
                   FontFamily="Yu Gothic UI" FontSize="13" Margin="0,0,0,4"/>
        <ProgressBar x:Name="Progress" Height="16" Minimum="0" Maximum="100"
                     Foreground="{DynamicResource ThemeAccent}" Background="{DynamicResource ThemePanel}"/>
    </StackPanel>
</Window>
