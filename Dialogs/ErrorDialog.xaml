<Window x:Class="ArchiveViewer.Dialogs.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="エラー" Width="450" Height="250" WindowStartupLocation="CenterOwner"
        Background="#1e1e2e" ResizeMode="NoResize" ShowInTaskbar="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="コピー" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnCopy_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="OK" Width="80" Padding="4" Click="BtnOk_Click"
                    Background="#7c3aed" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
        </StackPanel>
        <TextBox x:Name="ErrorText" IsReadOnly="True" TextWrapping="Wrap"
                 Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"
                 FontFamily="Yu Gothic UI" FontSize="12" Padding="8"
                 VerticalScrollBarVisibility="Auto"/>
    </DockPanel>
</Window>
