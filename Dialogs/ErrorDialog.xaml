<Window x:Class="ArchiveViewer.Dialogs.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="エラー" Width="450" Height="250" WindowStartupLocation="CenterOwner"
        Background="#3d1a30" ResizeMode="NoResize" ShowInTaskbar="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="コピー" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnCopy_Click"
                    Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"/>
            <Button Content="OK" Width="80" Padding="4" Click="BtnOk_Click"
                    Background="#e91e63" Foreground="#fce4ec" BorderBrush="#7a4868"/>
        </StackPanel>
        <TextBox x:Name="ErrorText" IsReadOnly="True" TextWrapping="Wrap"
                 Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"
                 FontFamily="Yu Gothic UI" FontSize="14" Padding="8"
                 VerticalScrollBarVisibility="Auto"/>
    </DockPanel>
</Window>
