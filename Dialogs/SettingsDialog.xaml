<Window x:Class="ArchiveViewer.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プリセット設定" Width="750" Height="620" WindowStartupLocation="CenterOwner"
        Background="#3d1a30" ResizeMode="CanResize" MinWidth="600" MinHeight="500">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MainPanel" Margin="0,0,8,0"/>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="閉じる" Width="100" Padding="6,4" Click="BtnClose_Click"
                    Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"
                    FontFamily="Yu Gothic UI" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
