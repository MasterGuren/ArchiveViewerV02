<Window x:Class="ArchiveViewer.Dialogs.PresetManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プリセット管理" Width="420" Height="450" WindowStartupLocation="CenterOwner"
        Background="#1e1e2e" ResizeMode="NoResize" ShowInTaskbar="False">
    <DockPanel Margin="16">
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="ロード" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnLoad_Click"
                    Background="#7c3aed" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="OK（順序保存）" Width="110" Padding="4" Click="BtnOk_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="新規" Width="60" Padding="4" Margin="0,0,4,0" Click="BtnNew_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="コピー" Width="60" Padding="4" Margin="0,0,4,0" Click="BtnCopy_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="名前変更" Width="80" Padding="4" Margin="0,0,4,0" Click="BtnRename_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="削除" Width="60" Padding="4" Margin="0,0,4,0" Click="BtnDelete_Click"
                    Background="#7f1d1d" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
        </StackPanel>

        <!-- Move buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="▲ 上へ" Width="80" Padding="4" Margin="0,0,4,0" Click="BtnUp_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="▼ 下へ" Width="80" Padding="4" Click="BtnDown_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
        </StackPanel>

        <!-- List -->
        <ListBox x:Name="PresetList" Background="#2a2a3e" Foreground="#e2e8f0"
                 BorderBrush="#3f3f5e" FontFamily="Yu Gothic UI" FontSize="13"
                 MouseDoubleClick="PresetList_DoubleClick"/>
    </DockPanel>
</Window>
