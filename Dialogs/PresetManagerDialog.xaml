<Window x:Class="ArchiveViewer.Dialogs.PresetManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="カテゴリ・リスト管理" Width="500" Height="520" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBg}" ResizeMode="NoResize" ShowInTaskbar="False">
    <DockPanel Margin="16">
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK（保存）" Width="110" Padding="4" Click="BtnOk_Click"
                    Background="{DynamicResource ThemeAccent}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
        </StackPanel>

        <!-- Preset action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="プリセット:" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Button Content="新規" Width="55" Padding="4" Margin="0,0,4,0" Click="BtnNew_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="コピー" Width="55" Padding="4" Margin="0,0,4,0" Click="BtnCopy_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="名前変更" Width="70" Padding="4" Margin="0,0,4,0" Click="BtnRename_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="削除" Width="55" Padding="4" Margin="0,0,4,0" Click="BtnDelete_Click"
                    Background="#7f1d1d" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
        </StackPanel>

        <!-- Move / category buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="▲" Width="35" Padding="4" Margin="0,0,4,0" Click="BtnUp_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="▼" Width="35" Padding="4" Margin="0,0,8,0" Click="BtnDown_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="カテゴリ変更" Width="90" Padding="4" Margin="0,0,4,0" Click="BtnChangeCategory_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
        </StackPanel>

        <!-- Category management -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="カテゴリ:" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Button Content="追加" Width="50" Padding="4" Margin="0,0,4,0" Click="BtnAddCategory_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="名前変更" Width="70" Padding="4" Margin="0,0,4,0" Click="BtnRenameCategory_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="削除" Width="50" Padding="4" Click="BtnDeleteCategory_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
        </StackPanel>

        <!-- TreeView -->
        <TreeView x:Name="PresetTree" Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}"
                  BorderBrush="{DynamicResource ThemeBorder}" FontFamily="Yu Gothic UI" FontSize="13"
                  Margin="0,0,0,0">
            <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
                    <Setter Property="IsExpanded" Value="True"/>
                </Style>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</Window>
