<Window x:Class="ArchiveViewer.Dialogs.PresetManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="カテゴリ・リスト管理" Width="500" Height="520" WindowStartupLocation="CenterOwner"
        Background="#1e1e2e" ResizeMode="NoResize" ShowInTaskbar="False">
    <DockPanel Margin="16">
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK（保存）" Width="110" Padding="4" Click="BtnOk_Click"
                    Background="#7c3aed" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
        </StackPanel>

        <!-- Preset action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="プリセット:" Foreground="#94a3b8" FontFamily="Yu Gothic UI" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Button Content="新規" Width="55" Padding="4" Margin="0,0,4,0" Click="BtnNew_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="コピー" Width="55" Padding="4" Margin="0,0,4,0" Click="BtnCopy_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="名前変更" Width="70" Padding="4" Margin="0,0,4,0" Click="BtnRename_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="削除" Width="55" Padding="4" Margin="0,0,4,0" Click="BtnDelete_Click"
                    Background="#7f1d1d" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
        </StackPanel>

        <!-- Move / category buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="▲" Width="35" Padding="4" Margin="0,0,4,0" Click="BtnUp_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="▼" Width="35" Padding="4" Margin="0,0,8,0" Click="BtnDown_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="カテゴリ変更" Width="90" Padding="4" Margin="0,0,4,0" Click="BtnChangeCategory_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
        </StackPanel>

        <!-- Category management -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="カテゴリ:" Foreground="#94a3b8" FontFamily="Yu Gothic UI" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Button Content="追加" Width="50" Padding="4" Margin="0,0,4,0" Click="BtnAddCategory_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="名前変更" Width="70" Padding="4" Margin="0,0,4,0" Click="BtnRenameCategory_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
            <Button Content="削除" Width="50" Padding="4" Click="BtnDeleteCategory_Click"
                    Background="#2a2a3e" Foreground="#e2e8f0" BorderBrush="#3f3f5e"/>
        </StackPanel>

        <!-- TreeView -->
        <TreeView x:Name="PresetTree" Background="#2a2a3e" Foreground="#e2e8f0"
                  BorderBrush="#3f3f5e" FontFamily="Yu Gothic UI" FontSize="13"
                  Margin="0,0,0,0">
            <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground" Value="#e2e8f0"/>
                    <Setter Property="IsExpanded" Value="True"/>
                </Style>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</Window>
