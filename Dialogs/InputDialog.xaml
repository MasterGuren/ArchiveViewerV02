<Window x:Class="ArchiveViewer.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="入力" Width="350" Height="160" WindowStartupLocation="CenterOwner"
        Background="#3d1a30" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptText" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,8"/>
        <TextBox x:Name="InputBox" Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"
                 CaretBrush="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Padding="4"
                 KeyDown="InputBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnOk_Click"
                    Background="#e91e63" Foreground="#fce4ec" BorderBrush="#7a4868"/>
            <Button Content="キャンセル" Width="80" Padding="4" Click="BtnCancel_Click"
                    Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"/>
        </StackPanel>
    </StackPanel>
</Window>
