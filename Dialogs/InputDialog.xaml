<Window x:Class="ArchiveViewer.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="入力" Width="350" Height="160" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBg}" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptText" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,8"/>
        <TextBox x:Name="InputBox" Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"
                 CaretBrush="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14" Padding="4"
                 KeyDown="InputBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnOk_Click"
                    Background="{DynamicResource ThemeAccent}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="キャンセル" Width="80" Padding="4" Click="BtnCancel_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
        </StackPanel>
    </StackPanel>
</Window>
