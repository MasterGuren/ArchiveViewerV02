<Window x:Class="ArchiveViewer.Dialogs.ConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ファイルの競合" Width="420" Height="240" WindowStartupLocation="CenterOwner"
        Background="#3d1a30" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock x:Name="FileNameText" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="13"
                   FontWeight="Bold" TextWrapping="Wrap"/>
        <TextBlock x:Name="SizeInfo" Foreground="#d4a0b0" FontFamily="Yu Gothic UI" FontSize="13"
                   Margin="0,8,0,0" TextWrapping="Wrap"/>
        <TextBlock x:Name="CompareText" Foreground="#f59e0b" FontFamily="Yu Gothic UI" FontSize="13"
                   Margin="0,4,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="上書き" Width="100" Padding="6" Margin="4" Click="BtnOverwrite_Click"
                    Background="#ef4444" Foreground="#fce4ec" BorderBrush="#7a4868"/>
            <Button Content="両方残す" Width="100" Padding="6" Margin="4" Click="BtnRename_Click"
                    Background="#3b82f6" Foreground="#fce4ec" BorderBrush="#7a4868"/>
            <Button Content="スキップ" Width="100" Padding="6" Margin="4" Click="BtnSkip_Click"
                    Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"/>
        </StackPanel>
    </StackPanel>
</Window>
