<Window x:Class="ArchiveViewer.Dialogs.ConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ファイルの競合" Width="420" Height="240" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBg}" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock x:Name="FileNameText" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="13"
                   FontWeight="Bold" TextWrapping="Wrap"/>
        <TextBlock x:Name="SizeInfo" Foreground="{DynamicResource ThemeSubtext}" FontFamily="Yu Gothic UI" FontSize="13"
                   Margin="0,8,0,0" TextWrapping="Wrap"/>
        <TextBlock x:Name="CompareText" Foreground="#f59e0b" FontFamily="Yu Gothic UI" FontSize="13"
                   Margin="0,4,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="上書き" Width="100" Padding="6" Margin="4" Click="BtnOverwrite_Click"
                    Background="#ef4444" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="両方残す" Width="100" Padding="6" Margin="4" Click="BtnRename_Click"
                    Background="#3b82f6" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="スキップ" Width="100" Padding="6" Margin="4" Click="BtnSkip_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
        </StackPanel>
    </StackPanel>
</Window>
