<Window x:Class="ArchiveViewer.Dialogs.ActionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="アクション編集" Width="380" Height="320" WindowStartupLocation="CenterOwner"
        Background="#3d1a30" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="ボタン名" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,4"/>
        <TextBox x:Name="LabelBox" Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"
                 CaretBrush="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Padding="4"
                 TextChanged="LabelBox_TextChanged"/>

        <TextBlock Text="色" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,12,0,4"/>
        <WrapPanel x:Name="ColorPanel"/>

        <TextBlock Text="プレビュー" Foreground="#fce4ec" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,12,0,4"/>
        <Button x:Name="PreviewBtn" Content="プレビュー" Width="120" Height="30"
                Foreground="#fce4ec" BorderBrush="#7a4868" FontFamily="Yu Gothic UI"
                HorizontalAlignment="Left"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnDelete" Content="削除" Width="80" Padding="4" Margin="0,0,8,0"
                    Background="#7f1d1d" Foreground="#fce4ec" BorderBrush="#7a4868"
                    Click="BtnDelete_Click" Visibility="Collapsed"/>
            <Button Content="OK" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnOk_Click"
                    Background="#e91e63" Foreground="#fce4ec" BorderBrush="#7a4868"/>
            <Button Content="キャンセル" Width="80" Padding="4" Click="BtnCancel_Click"
                    Background="#502842" Foreground="#fce4ec" BorderBrush="#7a4868"/>
        </StackPanel>
    </StackPanel>
</Window>
