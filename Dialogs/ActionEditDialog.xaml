<Window x:Class="ArchiveViewer.Dialogs.ActionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="アクション編集" Width="380" Height="320" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBg}" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="ボタン名" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,0,0,4"/>
        <TextBox x:Name="LabelBox" Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"
                 CaretBrush="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14" Padding="4"
                 TextChanged="LabelBox_TextChanged"/>

        <TextBlock Text="色" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,12,0,4"/>
        <WrapPanel x:Name="ColorPanel"/>

        <TextBlock Text="プレビュー" Foreground="{DynamicResource ThemeText}" FontFamily="Yu Gothic UI" FontSize="14" Margin="0,12,0,4"/>
        <Button x:Name="PreviewBtn" Content="プレビュー" Width="120" Height="30"
                Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}" FontFamily="Yu Gothic UI"
                HorizontalAlignment="Left"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnDelete" Content="削除" Width="80" Padding="4" Margin="0,0,8,0"
                    Background="#7f1d1d" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"
                    Click="BtnDelete_Click" Visibility="Collapsed"/>
            <Button Content="OK" Width="80" Padding="4" Margin="0,0,8,0" Click="BtnOk_Click"
                    Background="{DynamicResource ThemeAccent}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
            <Button Content="キャンセル" Width="80" Padding="4" Click="BtnCancel_Click"
                    Background="{DynamicResource ThemePanel}" Foreground="{DynamicResource ThemeText}" BorderBrush="{DynamicResource ThemeBorder}"/>
        </StackPanel>
    </StackPanel>
</Window>
