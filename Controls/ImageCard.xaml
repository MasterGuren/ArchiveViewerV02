<UserControl x:Class="ArchiveViewer.Controls.ImageCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MouseEnter="OnMouseEnter" MouseLeave="OnMouseLeave">
    <Border x:Name="CardBorder" Background="#2a2a3e" BorderBrush="Transparent" BorderThickness="2"
            CornerRadius="4" Padding="4" Cursor="Hand">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Thumbnail -->
            <Border Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="ThumbImage" Stretch="Uniform"/>
            </Border>
            <!-- Filename -->
            <TextBlock x:Name="NameLabel" Grid.Row="1" Foreground="#94a3b8"
                       FontFamily="Yu Gothic UI" FontSize="10"
                       TextTrimming="CharacterEllipsis" TextAlignment="Center"
                       Margin="0,2,0,0" MaxWidth="200"/>
            <!-- Badge -->
            <Border x:Name="BadgeBorder" Grid.Row="0"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Background="#7c3aed" CornerRadius="0,0,4,0" Padding="4,1">
                <TextBlock x:Name="BadgeText" Foreground="White"
                           FontFamily="Yu Gothic UI" FontSize="9" FontWeight="Bold"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
